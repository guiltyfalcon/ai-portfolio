# Environment setup
SHELL=/bin/zsh
PATH=/usr/local/bin:/usr/bin:/bin:/usr/local/sbin:/usr/sbin:/sbin

# Morning picks thread (9:00 AM ET) - AUTO-POST WITH INJURY CHECK
0 9 * * * cd /Users/djryan/git/guiltyfalcon/ai-portfolio/sports-betting-ai/api && export TELEGRAM_BOT_TOKEN=8733590521:AAH-dmhmMPABmnRcTvODry2z3hgMsV9Lo88 && export TELEGRAM_CHAT_ID=@betbrainaiwinner && python3 auto_post_picks.py >> /tmp/betbrain-auto-picks.log 2>&1

