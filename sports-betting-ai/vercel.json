{
  "version": 2,
  "functions": {
    "api/webhook.py": {
      "runtime": "python3.9",
      "maxDuration": 10
    },
    "api/email-capture/index.py": {
      "runtime": "python3.9",
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/api/webhook",
      "dest": "/api/webhook.py"
    },
    {
      "src": "/api/email-capture",
      "dest": "/api/email-capture/index.py"
    }
  ]
}
